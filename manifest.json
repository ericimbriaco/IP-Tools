{
  "manifest_version": 3,
  "name": "TitanRTX IP Tools",
  "description": "This Extension shows your IP Address",
  "version": "1.2",

  "action": {
    "default_popup": "/popup/index.html"
  },

  "icons":{

  },

  "permissions":[
    "clipboardWrite",
    "notifications",
    "storage"
  ],

  "background":{
    "service_worker": "background.js"
  }
}
