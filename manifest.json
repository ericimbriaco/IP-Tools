{
  "manifest_version": 3,
  "name": "IP Tools",
  "description": "Tools for checking my IP address, running a speed test, and generating QR codes.",
  "version": "1.5",

  "action": {
    "default_popup": "/popup/index.html"
  },

  "icons":{
    "16" : "/media/icon_16.png",
    "48" : "/media/icon_48.png",
    "128" : "/media/icon_128.png"
  },

  "permissions":[
    "clipboardWrite",
    "notifications",
    "storage",
    "downloads"
  ],

  "background":{
    "service_worker": "background.js"
  }
}
